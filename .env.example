# Copy to .env (or paste these keys into Dokploy's environment UI) and
# fill in the values you care about. Every var has a sensible default,
# so the only one you really have to set is CLAUDE_CODE_OAUTH_TOKEN.

# ---- Container identity ---------------------------------------------------
CONTAINER_NAME=claude-remote
DOCKERFILE_PATH=Dockerfile
TZ=Europe/Berlin

# ---- Auth -----------------------------------------------------------------
# Primary path: generate once on a machine with a browser:
#     claude setup-token
# then paste the resulting token below. Treat this as a secret.
CLAUDE_CODE_OAUTH_TOKEN=

# The OAuth token alone is not enough — claude-code also reads
# ~/.claude.json for onboarding state and account identity. The
# entrypoint writes that file from the three variables below on every
# boot, so set all three when using CLAUDE_CODE_OAUTH_TOKEN.
#
# How to find them: on a machine where `claude` is already logged in,
# look inside `~/.claude.json` under the `oauthAccount` object.
CLAUDE_ACCOUNT_UUID=
CLAUDE_EMAIL=
CLAUDE_ORGANIZATION_UUID=

# Optional. Bump if a new claude-code release requires a newer value.
CLAUDE_ONBOARDING_VERSION=2.1.29

# Fallback path: set SETUP_MODE=true for a one-shot interactive login via
# `docker exec` / the Dokploy terminal (`claude`, `/login`, `/status`),
# then flip back to false and redeploy. The login is persisted on the
# claude-config-data volume.
SETUP_MODE=false

# ---- Runtime --------------------------------------------------------------
SPAWN_WORKTREE_SESSIONS=5

# ---- SSH (optional) -------------------------------------------------------
# sshd only starts when ENABLE_SSH=true. The port is always published on
# the host so you can toggle the server on from the Dokploy env UI without
# editing compose; when disabled, nothing listens inside the container.
ENABLE_SSH=false
SSH_HOST_PORT=2222

# ---- Healthcheck ----------------------------------------------------------
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=30s
