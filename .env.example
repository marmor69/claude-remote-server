# Copy to .env (or paste these keys into Dokploy's environment UI).
# Every var has a sensible default; the ones you have to set are the
# three CLAUDE_* identity vars below, and only after your first login.

# ---- Container identity ---------------------------------------------------
CONTAINER_NAME=claude-remote
DOCKERFILE_PATH=Dockerfile
TZ=Europe/Berlin

# ---- Auth -----------------------------------------------------------------
# `claude remote-control server` only works with subscription auth
# obtained via the interactive `/login` flow. Long-lived OAuth tokens
# (CLAUDE_CODE_OAUTH_TOKEN from `claude setup-token`) are NOT supported.
#
# First-time setup:
#   1. Deploy with SETUP_MODE=true.
#   2. Open a container terminal (Dokploy terminal or `docker exec`) and run:
#          claude
#          /login
#          /status
#   3. After /status confirms subscription auth, run:
#          jq '.oauthAccount' ~/.claude.json
#      and paste the three fields into the three CLAUDE_* vars below.
#   4. Set SETUP_MODE=false and redeploy.
#
# The short-lived credentials persist on the claude-config-data volume.
# The entrypoint regenerates ~/.claude.json from these env vars on every
# boot, so Dokploy redeploys don't lose onboarding state.
SETUP_MODE=false

CLAUDE_ACCOUNT_UUID=
CLAUDE_EMAIL=
CLAUDE_ORGANIZATION_UUID=

# Optional. Bump if a new claude-code release requires a newer value.
CLAUDE_ONBOARDING_VERSION=2.1.29

# ---- Runtime --------------------------------------------------------------
SPAWN_WORKTREE_SESSIONS=5

# ---- SSH (optional) -------------------------------------------------------
# sshd only starts when ENABLE_SSH=true. The port is always published on
# the host so you can toggle the server on from the Dokploy env UI without
# editing compose; when disabled, nothing listens inside the container.
ENABLE_SSH=false
SSH_HOST_PORT=2222

# ---- Healthcheck ----------------------------------------------------------
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=30s
