# Copy to .env (or paste these keys into Dokploy's environment UI).
# Every var has a sensible default — the only one you typically toggle
# is SETUP_MODE during the one-time interactive login.

# ---- Container identity ---------------------------------------------------
CONTAINER_NAME=claude-remote
DOCKERFILE_PATH=Dockerfile
TZ=Europe/Berlin

# ---- Auth -----------------------------------------------------------------
# `claude remote-control server` only works with subscription auth
# obtained via the interactive `/login` flow. Long-lived OAuth tokens
# (CLAUDE_CODE_OAUTH_TOKEN from `claude setup-token`) are NOT supported.
#
# First-time setup:
#   1. Deploy with SETUP_MODE=true.
#   2. Open a container terminal (Dokploy terminal or `docker exec`) and run:
#          claude
#          /login
#          /status
#   3. Set SETUP_MODE=false and redeploy.
#
# Everything claude-code writes lives under $HOME, and $HOME is a
# persistent named volume (claude-home-data), so credentials and
# onboarding state survive redeploys with no further configuration.
SETUP_MODE=false

# ---- Runtime --------------------------------------------------------------
SPAWN_WORKTREE_SESSIONS=5

# ---- SSH (optional) -------------------------------------------------------
# sshd only starts when ENABLE_SSH=true. The port is always published on
# the host so you can toggle the server on from the Dokploy env UI without
# editing compose; when disabled, nothing listens inside the container.
ENABLE_SSH=false
SSH_HOST_PORT=2222

# ---- Healthcheck ----------------------------------------------------------
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=30s
