# Copy to .env (or paste these keys into Dokploy's environment UI).
# Every var has a sensible default — the only one you typically toggle
# is SETUP_MODE during the one-time interactive login.

# ---- Container identity ---------------------------------------------------
CONTAINER_NAME=claude-remote
# The container hostname becomes the `machine_name` shown next to each
# environment in claude.ai/code AND the default session name prefix.
# A stable value keeps the dashboard entry named consistently across
# redeploys instead of a fresh random container hash every time.
CONTAINER_HOSTNAME=claude-remote-server
DOCKERFILE_PATH=Dockerfile
TZ=Europe/Berlin

# Time Docker waits for `claude remote-control` to archive sessions and
# deregister its environment on SIGTERM. If it's too short the container
# gets SIGKILL'd mid-cleanup and leaves a stale environment in
# claude.ai/code. 60s is plenty.
STOP_GRACE_PERIOD=60s

# ---- Auth -----------------------------------------------------------------
# `claude remote-control server` only works with subscription auth
# obtained via the interactive `/login` flow. Long-lived OAuth tokens
# (CLAUDE_CODE_OAUTH_TOKEN from `claude setup-token`) are NOT supported.
#
# First-time setup:
#   1. Deploy with SETUP_MODE=true.
#   2. Open a container terminal (Dokploy terminal or `docker exec`) and run:
#          claude
#          /login
#          /status
#   3. Set SETUP_MODE=false and redeploy.
#
# Everything claude-code writes lives under $HOME, and $HOME is a
# persistent named volume (claude-home-data), so credentials and
# onboarding state survive redeploys with no further configuration.
SETUP_MODE=false

# ---- Remote-control server flags ------------------------------------------
# Spawn mode for on-demand sessions:
#   worktree  — each session gets its own git worktree (default here;
#               requires /home/claude/workspace to be a git repo)
#   same-dir  — all sessions share the working directory (claude-code default)
#   session   — single-session mode; rejects additional connections
SPAWN_MODE=worktree

# Max concurrent sessions (claude-code default is 32). Leave empty to
# use the built-in default. Not compatible with SPAWN_MODE=session.
CAPACITY=

# Optional session title shown in the list at claude.ai/code.
SESSION_NAME=

# Prefix for auto-generated session names. Defaults to the container
# hostname if empty, producing names like <hostname>-graceful-unicorn.
CLAUDE_REMOTE_CONTROL_SESSION_NAME_PREFIX=

# Extra startup logging.
VERBOSE=false

# Filesystem / network isolation for spawned sessions. Off by default.
SANDBOX=false

# ---- SSH (optional) -------------------------------------------------------
# sshd only starts when ENABLE_SSH=true. The port is always published on
# the host so you can toggle the server on from the Dokploy env UI without
# editing compose; when disabled, nothing listens inside the container.
ENABLE_SSH=false
SSH_HOST_PORT=2222

# ---- Healthcheck ----------------------------------------------------------
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=30s
